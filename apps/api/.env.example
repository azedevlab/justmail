# JustMail API configuration.
# Generated from the config schema — regenerate with:
#   pnpm --filter @justmail/api config:sample
# Copy to .env and fill in the required values. Never commit real secrets.

# ── Required (no default; must be set) ──
DATABASE_URL=            # string (uri)
ENCRYPTION_KEY=            # string, min 32
EVENTS_INGEST_TOKEN=            # string, min 16

# ── Optional (defaults shown; uncomment to override) ──
# NODE_ENV=development            # one of: development, test, production
# PORT=4000            # integer
# DATABASE_READONLY_URL=            # string (uri)
# REDIS_URL=            # string (uri)
# REDIS_MAX_RETRIES_PER_REQUEST=2            # integer
# SESSION_TTL_DAYS=30            # integer
# DKIM_DIR=/var/lib/justmail/dkim            # string
# DKIM_ROTATION_ENABLED=false            # boolean
# DKIM_ROTATION_DAYS=90            # integer
# DKIM_ROTATION_OVERLAP_HOURS=24            # integer
# DKIM_ROTATION_POLL_SECONDS=3600            # integer
# MAIL_HOSTNAME=mail.localhost            # string
# IMAP_HOST=dovecot            # string
# IMAP_PORT=993            # integer
# IMAP_TLS_REJECT_UNAUTHORIZED=false            # boolean
# IMAP_POOL_MAX=256            # integer
# IMAP_POOL_IDLE_TTL_SECONDS=300            # integer
# DOVECOT_MASTER_USER=            # string
# DOVECOT_MASTER_PASSWORD=            # string
# SMTP_HOST=postfix            # string
# SMTP_PORT=587            # integer
# SMTP_TLS_REJECT_UNAUTHORIZED=false            # boolean
# SIEVE_HOST=dovecot            # string
# SIEVE_PORT=4190            # integer
# SIEVE_TLS_REJECT_UNAUTHORIZED=false            # boolean
# SIEVE_SCRIPT_NAME=justmail            # string
# SIEVE_CONNECT_TIMEOUT_SECONDS=15            # integer
# RADICALE_URL=http://radicale:5232            # string (uri)
# RADICALE_CONTACTS_COLLECTION=contacts            # string
# RADICALE_CALENDAR_COLLECTION=calendar            # string
# THUMBNAIL_ENABLED=true            # boolean
# THUMBNAIL_MAX_DIM=320            # integer
# THUMBNAIL_QUALITY=72            # integer
# THUMBNAIL_SOURCE_MAX_BYTES=25000000            # integer
# CLAMAV_ENABLED=true            # boolean
# CLAMAV_HOST=clamav            # string
# CLAMAV_PORT=3310            # integer
# CLAMAV_TIMEOUT_MS=30000            # integer
# CLAMAV_CHUNK_BYTES=65536            # integer
# WEBMAIL_ATTACHMENT_MAX_TOTAL_BYTES=15000000            # integer
# WEBMAIL_ATTACHMENT_MAX_COUNT=16            # integer
# WEBMAIL_ATTACHMENT_INLINE_MAX_BYTES=2000000            # integer
# WEBMAIL_SEND_BODY_LIMIT=32mb            # string
# WEBMAIL_MESSAGE_LIST_MAX=200            # integer
# WEBMAIL_CREDENTIAL_TTL_SECONDS=3600            # integer
# WEBMAIL_CACHE_TTL_SECONDS=20            # integer
# WEBMAIL_UNDO_SEND_SECONDS=10            # integer
# WEBMAIL_SCHEDULED_SEND_MAX_DAYS=30            # integer
# WEBMAIL_SEND_POLL_SECONDS=3            # integer
# WEBMAIL_SEND_MAX_ATTEMPTS=3            # integer
# WEBMAIL_SEND_RETRY_SECONDS=60            # integer
# WEBMAIL_SEND_CLAIM_TIMEOUT_SECONDS=120            # integer
# WEB_PUSH_VAPID_PUBLIC_KEY=            # string
# WEB_PUSH_VAPID_PRIVATE_KEY=            # string
# WEB_PUSH_SUBJECT=            # string
# SSO_CALLBACK_BASE_URL=            # string (uri)
# SSO_DEFAULT_RELAY_URL=            # string (uri)
# SSO_FLOW_TTL_SECONDS=600            # integer
# OIDC_HTTP_TIMEOUT_SECONDS=8            # integer
# OIDC_METADATA_CACHE_TTL_SECONDS=3600            # integer
# PG_DUMP_BIN=pg_dump            # string
# PG_RESTORE_BIN=pg_restore            # string
# BACKUP_POLL_SECONDS=300            # integer
# WEBHOOK_POLL_SECONDS=5            # integer
# WEBHOOK_DELIVERY_TIMEOUT_SECONDS=10            # integer
# QUEUE_SNAPSHOT_POLL_SECONDS=60            # integer
# DNSBL_POLL_SECONDS=1800            # integer
# DNS_RECHECK_POLL_SECONDS=300            # integer
# CRED_SWEEP_POLL_SECONDS=600            # integer
# LDAP_POLL_SECONDS=60            # integer
# RETENTION_POLL_SECONDS=3600            # integer
# RATE_LIMIT_GLOBAL_TTL=60            # integer
# RATE_LIMIT_GLOBAL_MAX=300            # integer
# RATE_LIMIT_AUTH_TTL=60            # integer
# RATE_LIMIT_AUTH_MAX=10            # integer
# JM_WEB_HOST=            # string
# JM_ADMIN_HOST=            # string
# JM_WEBMAIL_HOST=            # string
# JM_LANDING_HOST=            # string
# JM_API_HOST=            # string
# WEBAUTHN_RP_ID=            # string
# WEBAUTHN_RP_NAME=JustMail            # string
# WEBAUTHN_ORIGINS=            # string
# WEBAUTHN_CHALLENGE_TTL_SECONDS=300            # integer
