{
  "name": "@justmail/theme-engine",
  "version": "1.0.0-alpha.1",
  "description": "Runtime theme compiler: token → CSS with :root / [data-org] / [data-domain] cascade.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
