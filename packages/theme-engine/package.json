      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@justmail/contracts": "workspace:*",
    "@justmail/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
