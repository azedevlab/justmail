{
  "name": "@justmail/design-tokens",
  "version": "1.0.0-alpha.1",
  "description": "Design tokens for JustMail (Style Dictionary sources + generated outputs).",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
