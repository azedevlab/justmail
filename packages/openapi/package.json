{
  "name": "@justmail/openapi",
  "version": "1.0.0-alpha.1",
  "description": "Compile Zod schemas + route metadata into an OpenAPI 3.1 document.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@justmail/contracts": "workspace:*",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
