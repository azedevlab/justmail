{
  "name": "@justmail/shared-utils",
  "version": "1.0.0-alpha.1",
  "description": "Cross-app helpers: typed fetch client, React hooks, i18n, formatters.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "dependencies": {
    "@justmail/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "react": "^19.0.0",
    "typescript": "^7.0.2"
  }
}
