# JustMail Dovecot — golden template. Auth/userdb state lives in PostgreSQL views.

protocols = imap pop3 lmtp sieve
listen = *
log_path = /dev/stdout
info_log_path = /dev/stdout
auth_verbose = yes
auth_mechanisms = plain login
disable_plaintext_auth = yes

mail_home = /var/vmail/%d/%n
mail_location = maildir:/var/vmail/%d/%n/Maildir
mail_uid = 5000
mail_gid = 5000
first_valid_uid = 5000
last_valid_uid = 5000

# Shared/distributed maildir tuning (index + lock coherence). Rendered by the
# entrypoint from MAIL_STORAGE_BACKEND; empty for local disk. See
# docs/deployment/shared-storage.md.
!include_try /etc/dovecot/shared-storage.conf

ssl = required
ssl_cert = </certs/mail/fullchain.pem
ssl_key = </certs/mail/key.pem
ssl_min_protocol = TLSv1.2
ssl_prefer_server_ciphers = yes

passdb {
  driver = sql
  args = /etc/dovecot/dovecot-sql.conf.ext
}
userdb {
  driver = prefetch
}
userdb {
  driver = sql
  args = /etc/dovecot/dovecot-sql.conf.ext
}

# Postfix SASL + LMTP delivery
service auth {
  inet_listener {
    port = 12345
  }
}
service lmtp {
  inet_listener lmtp {
    port = 24
  }
}

service imap-login {
  inet_listener imap {
    port = 0
  }
  inet_listener imaps {
    port = 993
    ssl = yes
  }
}
service pop3-login {
  inet_listener pop3 {
    port = 0
  }
  inet_listener pop3s {
    port = 995
    ssl = yes
  }
}
service managesieve-login {
  inet_listener sieve {
    port = 4190
  }
}

mail_plugins = $mail_plugins quota
protocol imap {
  mail_plugins = $mail_plugins imap_quota imap_sieve
  mail_max_userip_connections = 20
}
protocol lmtp {
  mail_plugins = $mail_plugins sieve
  postmaster_address = postmaster@${JM_DOMAIN}
}
protocol pop3 {
  pop3_uidl_format = %08Xu%08Xv
}

plugin {
  quota = maildir:User quota
  quota_status_success = DUNNO
  quota_status_nouser = DUNNO
  quota_status_overquota = "552 5.2.2 Mailbox is over quota"
  sieve = file:/var/vmail/%d/%n/sieve;active=/var/vmail/%d/%n/.dovecot.sieve

  # IMAPSieve → rspamd Bayes training. Moving a message into Junk trains spam;
  # moving it back out trains ham. Scripts stream the message to the rspamd
  # controller (see report-*.sieve / learn-*.sh, installed by the entrypoint).
  sieve_plugins = sieve_imapsieve sieve_extprograms
  sieve_global_extensions = +vnd.dovecot.pipe
  sieve_pipe_bin_dir = /etc/dovecot/sieve

  imapsieve_mailbox1_name = Junk
  imapsieve_mailbox1_causes = COPY APPEND
  imapsieve_mailbox1_before = file:/etc/dovecot/sieve/report-spam.sieve

  imapsieve_mailbox2_name = *
  imapsieve_mailbox2_from = Junk
  imapsieve_mailbox2_causes = COPY
  imapsieve_mailbox2_before = file:/etc/dovecot/sieve/report-ham.sieve
}

namespace inbox {
  inbox = yes
  separator = /
  mailbox Drafts {
    special_use = \Drafts
    auto = subscribe
  }
  mailbox Sent {
    special_use = \Sent
    auto = subscribe
  }
  mailbox Trash {
    special_use = \Trash
    auto = subscribe
  }
  mailbox Junk {
    special_use = \Junk
    auto = subscribe
  }
  mailbox Archive {
    special_use = \Archive
    auto = subscribe
  }
}
