# JustMail environment. Copy to .env, fill secrets, keep chmod 600.

# ── Hostnames ──────────────────────────────────────────────────────────────
JM_DOMAIN=example.com
JM_ADMIN_HOST=admin.example.com
JM_WEBMAIL_HOST=mail.example.com
JM_API_HOST=api.example.com
JM_GRAFANA_HOST=grafana.example.com
MAIL_HOSTNAME=mail.example.com
JM_HOSTNAME=mail.example.com
ACME_EMAIL=postmaster@example.com

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_DB=justmail
POSTGRES_USER=justmail
POSTGRES_PASSWORD=change-me-strong
MAILPLANE_DB_PASSWORD=change-me-strong

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong

# ── Rspamd ─────────────────────────────────────────────────────────────────
# Controller password guarding Bayes learn requests from Dovecot IMAPSieve.
RSPAMD_CONTROLLER_PASSWORD=change-me-strong

# ── Antivirus (clamd) ──────────────────────────────────────────────────────
# Outbound attachments are INSTREAM-scanned before send. Host/port default to
# the compose `clamav` service; set CLAMAV_ENABLED=false to disable scanning.
CLAMAV_ENABLED=true

# ── Thumbnails (sharp) ─────────────────────────────────────────────────────
# Image attachments get a webp card thumbnail on finalise. Set
# THUMBNAIL_ENABLED=false to skip generation; tune dimension/quality per deploy.
THUMBNAIL_ENABLED=true

# ── App secrets (generate: openssl rand -hex 32) ──────────────────────────
APP_SECRET=
ENCRYPTION_KEY=
EVENTS_INGEST_TOKEN=

# ── Web Push (browser notifications) ──────────────────────────────────────
# Generate a VAPID key pair with `npx web-push generate-vapid-keys`. Push is
# disabled until both keys are set. Subject defaults to postmaster@MAIL_HOSTNAME.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:postmaster@example.com

# ── Single sign-on (OIDC/SAML) ─────────────────────────────────────────────
# Providers are configured per-org in the admin console; these only tune the
# callback URLs the browser is redirected through. The callback base must be the
# public API host and match what you register at the IdP; it defaults to
# https://$JM_API_HOST. After login the user returns to the relay target, which
# defaults to the admin console ($JM_ADMIN_HOST).
# SSO_CALLBACK_BASE_URL=https://api.example.com
# SSO_DEFAULT_RELAY_URL=https://admin.example.com
# SSO_FLOW_TTL_SECONDS=600

# ── Passkeys (WebAuthn) ────────────────────────────────────────────────────
# The relying-party ID must be a registrable domain shared by the admin and
# webmail origins (their common parent). It defaults to the cookie domain
# ($JM_WEB_HOST). Browser origins are derived from the app hosts unless you
# override them with a comma-separated list.
# WEBAUTHN_RP_ID=example.com
# WEBAUTHN_RP_NAME=JustMail
# WEBAUTHN_ORIGINS=https://admin.example.com,https://mail.example.com
# WEBAUTHN_CHALLENGE_TTL_SECONDS=300

# ── DNS provider ──────────────────────────────────────────────────────────
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Storage ───────────────────────────────────────────────────────────────
STORAGE_KIND=local
STORAGE_LOCAL_PATH=/opt/justmail/attachments
# For S3-flavoured providers, uncomment and fill:
# STORAGE_KIND=s3
# STORAGE_BUCKET=justmail-prod
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# ── Outbound mail ─────────────────────────────────────────────────────────
# smarthost example: [email-smtp.eu-north-1.amazonaws.com]:587
OUTBOUND_MODE=direct
RELAYHOST=
RELAYHOST_USER=
RELAYHOST_PASSWORD=

# ── Monitoring ────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-strong

# ── Limits ────────────────────────────────────────────────────────────────
MESSAGE_SIZE_LIMIT=52428800  # 50 MiB

# ── Backups (optional) ────────────────────────────────────────────────────
# BACKUP_S3_URI=s3://backups-prod/justmail/
