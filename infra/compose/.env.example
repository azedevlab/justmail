# JustMail environment — copy to /opt/justmail/.env (chmod 600). Never commit real values.

# ── Identity ────────────────────────────────────────────────────────────────
JM_DOMAIN=devlab.az                      # primary mail domain
JM_HOSTNAME=mail.devlab.az               # MTA hostname (must match PTR when direct-sending)
JM_WEB_HOST=justmail.devlab.az           # admin UI
JM_API_HOST=api.justmail.devlab.az       # API + WebSocket
JM_GRAFANA_HOST=grafana.justmail.devlab.az
ACME_EMAIL=admin@devlab.az               # Let's Encrypt account

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=justmail
POSTGRES_USER=justmail
POSTGRES_PASSWORD=change-me-strong
MAILPLANE_DB_PASSWORD=change-me-strong   # restricted role used by postfix/dovecot (views only)

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong

# ── Cloudflare (DNS-01 certs + DNS Center) ─────────────────────────────────
# Token scopes: Zone.DNS:Edit on the target zone(s) only.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Application secrets (generate: openssl rand -hex 32) ───────────────────
APP_SECRET=                              # session signing
ENCRYPTION_KEY=                          # AES-GCM for DKIM private keys at rest
EVENTS_INGEST_TOKEN=                     # vector -> api log-event ingestion

# ── Outbound mail ───────────────────────────────────────────────────────────
# AWS blocks outbound port 25 until the limit-removal request is approved.
# smarthost example: [email-smtp.eu-north-1.amazonaws.com]:587
OUTBOUND_MODE=smarthost                  # smarthost | direct
RELAYHOST=
RELAYHOST_USER=
RELAYHOST_PASSWORD=

# ── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-strong

# ── Limits ──────────────────────────────────────────────────────────────────
MESSAGE_SIZE_LIMIT=52428800              # 50 MiB
